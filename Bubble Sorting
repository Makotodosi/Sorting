#include <iostream>

using namespace std;

void print(int num[], int size) //вывод массива на экран
{
	for (int i = 0; i < size; i++)
	{
		cout << num[i] << "   ";
	}
}

void bubble(int num[], int size) //сортировка пузырьком
{
	for (int i = 0; i < size; i++) //проходим массив size^2 раз, чтобы все цифры встали на свои места 
	{
		for (int j = 0; j < size - 1; j++)
		{
			if (num[j] > num[j + 1]) //если текущий элемент больше следующего,то
			{
				swap(num[j], num[j + 1]); //меняем их местами, получается, 
				//что все мелкие числа двигаются поочереди налево и числа встают "по возврастанию"
			}
		}
	}
	
}

int main()
{
	setlocale (LC_ALL, "ru");

	const int n = 10;
	int num[n] = { 8, 5, 10, 2, 3, 6, 1, 4, 7, 9 };
	cout << "Было: " << endl;
	print(num, n);

	bubble(num, n);

	cout << "\nСтало: \n";
	print(num, n);
	
}
