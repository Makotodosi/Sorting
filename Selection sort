	const int n = 10;
	int num[n] = { 8, 5, 10, 2, 3, 6, 1, 4, 7, 9 };
	cout << "Было: " << endl;
	print(num, n);

	сhoice(num, n);

	cout << "\nСтало: \n";
	print(num, n);
}
