#include <iostream>

using namespace std;

void print(int num[], int size) //вывод массива на экран
{
	for (int i = 0; i < size; i++)
	{
		cout << num[i] << "   ";
	}
}

void insert(int num[], int size) //сортировка вставками
{
	for (int i = 1; i < size; i++)
	{
		for (int j = i; j > 0 && num[j - 1] > num[j]; j--) /*j перемещает самую маленькую цифру влево
		пока она не будет меньше всех цифр, что стоят справа*/
		{
			swap(num[j], num[j - 1]);
		}
	}
}

int main()
{
	setlocale (LC_ALL, "ru");

	const int n = 10;
	int num[n] = { 8, 5, 10, 2, 3, 6, 1, 4, 7, 9 };
	cout << "Было: " << endl;
	print(num, n);

	insert(num, n);

	cout << "\nСтало: \n";
	print(num, n);
	
}
